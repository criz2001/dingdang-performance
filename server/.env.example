# 叮当绩效 - 后端环境配置
# 复制此文件为 .env 并修改配置

# 应用配置
APP_PORT=3000
APP_PREFIX=/api

# 数据库配置 - DB_TYPE 可选 sqlite 或 mysql
DB_TYPE=sqlite

# SQLite 配置（DB_TYPE=sqlite 时生效）
SQLITE_PATH=./data/dingdang.db

# MySQL 配置（DB_TYPE=mysql 时生效）
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USERNAME=root
MYSQL_PASSWORD=123456
MYSQL_DATABASE=dingdang_performance

# JWT 配置
JWT_SECRET=dingdang_performance_jwt_secret_2024
JWT_EXPIRES_IN=7d

# 种子数据密码（体验版统一默认密码）
DEFAULT_PASSWORD=123456
