# 叮当绩效 - 环境配置模板
# 复制此文件为 .env 并填写实际值

# ===== 数据库配置 =====
# 体验版默认使用 SQLite（本地文件数据库）
# 部署到服务器时切换为 MySQL
DB_TYPE=sqlite

# SQLite 配置（体验版使用）
DB_SQLITE_PATH=./data/dingdang.db

# MySQL 配置（生产环境使用，体验版可忽略）
DB_HOST=localhost
DB_PORT=3306
DB_NAME=dingdang
DB_USER=root
DB_PASS=your_mysql_password

# ===== Redis 配置 =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASS=

# ===== JWT 配置 =====
JWT_SECRET=your_jwt_secret_change_this_in_production
JWT_EXPIRES_IN=7d

# ===== 企业微信配置（体验版可忽略，生产环境填写） =====
WECOM_CORP_ID=
WECOM_CORP_SECRET=
WECOM_AGENT_ID=

# ===== 应用配置 =====
APP_PORT=3000
APP_NAME=叮当绩效
NODE_ENV=development